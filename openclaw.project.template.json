{
  "meta": {
    "lastTouchedVersion": "2026.3.2",
    "lastTouchedAt": "2026-03-16T00:00:00.000Z"
  },
  "wizard": {
    "lastRunAt": "2026-03-16T00:00:00.000Z",
    "lastRunVersion": "2026.3.2",
    "lastRunCommand": "configure",
    "lastRunMode": "local"
  },
  "secrets": {
    "providers": {
      "google_oauth_client": {
        "source": "file",
        "path": "/ABSOLUTE/PATH/TO/SECRETS/google-oauth-client.json",
        "mode": "json"
      }
    }
  },
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openai-custom": {
        "baseUrl": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT/v1",
        "apiKey": "REPLACE_WITH_PROVIDER_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "openai-custom/YOUR_MODEL_ID",
            "name": "YOUR_MODEL_NAME",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-custom/YOUR_MODEL_ID"
      },
      "models": {
        "openai-custom/YOUR_MODEL_ID": {}
      },
      "workspace": "/ABSOLUTE/PATH/TO/WORKSPACE",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "openclaw": {
          "enabled": false
        }
      },
      "installs": {}
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "REPLACE_WITH_TELEGRAM_BOT_TOKEN",
      "groups": {
        "-1000000000000": {
          "requireMention": true
        }
      },
      "allowFrom": [
        "YOUR_TELEGRAM_USER_ID"
      ],
      "groupAllowFrom": [
        "YOUR_TELEGRAM_USER_ID"
      ],
      "groupPolicy": "allowlist",
      "streaming": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "REPLACE_WITH_GATEWAY_TOKEN"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  }
}
